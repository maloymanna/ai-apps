{
  "manifest_version": 3,
  "name": "Read Aloud",
  "version": "1.0",
  "description": "Read selected text or full page with Text to Speech",
  "permissions": ["scripting", "activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
      "default_icon": {
      "16": "icons/edge-tts16.png",
      "48": "icons/edge-tts48.png",
      "128": "icons/edge-tts128.png"
    }
  }
}